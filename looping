#include <Arduino.h>

// ===== Pins =====
#define INPUT_PIN 26      // GP26 (ADC0)
#define OUTPUT_PIN 3      // PWM output to amp
#define SQUARE_PIN 6      // generates square wave
#define BUTTON_PIN 2      // capture trigger

#define WAVE_LEN 256

uint8_t wave[WAVE_LEN];
bool captured = false;

// ===== Setup =====
void setup() {
  pinMode(SQUARE_PIN, OUTPUT);
  pinMode(OUTPUT_PIN, OUTPUT);
  pinMode(BUTTON_PIN, INPUT_PULLUP);

  analogReadResolution(10);   // 0–1023
  analogWriteRange(255);      // 8-bit PWM
}

// ===== Capture waveform =====
void captureWave() {
  for (int i = 0; i < WAVE_LEN; i++) {
    int val = analogRead(INPUT_PIN);   // 0–1023
    wave[i] = val >> 2;               // convert to 0–255
    delayMicroseconds(200);           // ~5 kHz sampling
  }
}

// ===== Loop =====
void loop() {

  // ---- Generate slower square wave (matches 10k + 220nF) ----
  digitalWrite(SQUARE_PIN, HIGH);
  delayMicroseconds(1000);
  digitalWrite(SQUARE_PIN, LOW);
  delayMicroseconds(1000);

  // ---- Button press = capture ----
  if (digitalRead(BUTTON_PIN) == LOW) {
    captureWave();
    captured = true;
    delay(300); // debounce
  }

  // ---- Playback ----
  if (captured) {
    for (int i = 0; i < WAVE_LEN; i++) {
      analogWrite(OUTPUT_PIN, wave[i]);
      delayMicroseconds(200); // match capture rate
    }
  }
}
