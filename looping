#include <Arduino.h>

// ===== Pins =====
#define INPUT_PIN   26   // GP26 (RC input)
#define OUTPUT_PIN  3    // GP3 (to amp)
#define SQUARE_PIN  6    // GP6 (drives RC)
#define BUTTON_PIN  2    // button

// ===== Settings =====
#define SAMPLE_RATE     2000      // samples per second
#define RECORD_SECONDS  5
#define NUM_SAMPLES     (SAMPLE_RATE * RECORD_SECONDS)

uint8_t wave[NUM_SAMPLES];
bool captured = false;

const uint32_t SAMPLE_US = 1000000UL / SAMPLE_RATE;

// ===== Setup =====
void setup() {
  pinMode(SQUARE_PIN, OUTPUT);
  pinMode(OUTPUT_PIN, OUTPUT);
  pinMode(BUTTON_PIN, INPUT_PULLUP);

  analogReadResolution(10);
  analogWriteRange(255);

  Serial.begin(115200);
  delay(2000);
  Serial.println("Ready - press button");
}

// ===== Capture 5 seconds =====
void captureWave() {
  Serial.println("Recording 5 seconds...");

  bool sq = false;

  for (int i = 0; i < NUM_SAMPLES; i++) {
    uint32_t t = micros();

    // drive RC circuit
    sq = !sq;
    digitalWrite(SQUARE_PIN, sq);

    int val = analogRead(INPUT_PIN);
    wave[i] = val >> 2;

    // timing
    while (micros() - t < SAMPLE_US);
  }

  digitalWrite(SQUARE_PIN, LOW);

  Serial.println("Recording done!");
}

// ===== Play loop with clear markers =====
void playLoop() {

  // 🔊 LOOP START MARKER (clear beep)
  for (int i = 0; i < 300; i++) {
    digitalWrite(OUTPUT_PIN, HIGH);
    delayMicroseconds(800);
    digitalWrite(OUTPUT_PIN, LOW);
    delayMicroseconds(800);
  }

  delay(150); // short silence → easier to hear boundary

  // PLAY BACK RECORDED WAVE
  for (int i = 0; i < NUM_SAMPLES; i++) {

    int centered = wave[i] - 128;

    // slight boost so it's audible
    int out = 128 + (centered * 2);

    if (out < 0) out = 0;
    if (out > 255) out = 255;

    analogWrite(OUTPUT_PIN, out);

    uint32_t t = micros();
    while (micros() - t < SAMPLE_US);
  }

  // 🔇 LOOP END MARKER (silence)
  analogWrite(OUTPUT_PIN, 128);
  delay(300);
}

// ===== Loop =====
void loop() {

  if (!captured) {
    if (digitalRead(BUTTON_PIN) == LOW) {
      delay(20);

      if (digitalRead(BUTTON_PIN) == LOW) {
        Serial.println("Button pressed!");

        captureWave();
        captured = true;

        // wait for release
        while (digitalRead(BUTTON_PIN) == LOW) {
          delay(5);
        }
      }
    }
  } else {
    playLoop();
  }
}
