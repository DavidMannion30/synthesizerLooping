#include <Arduino.h>

#define OUTPUT_PIN 3
#define WAVE_LEN 256

uint8_t wave[WAVE_LEN];

void setup() {
  pinMode(OUTPUT_PIN, OUTPUT);

  // Fill with ramp
  for (int i = 0; i < WAVE_LEN; i++) {
    wave[i] = i;
  }

  // ---- BIG loop marker ----
  // Force a noticeable discontinuity
  for (int i = 0; i < 20; i++) {
    wave[i] = 0;   // silence
  }

  wave[20] = 255;  // sharp spike
}
