#include <Arduino.h>

#define OUTPUT_PIN 3
#define WAVE_LEN 256

uint8_t wave[WAVE_LEN];

void setup() {
  pinMode(OUTPUT_PIN, OUTPUT);

  // Fill with ramp
  for (int i = 0; i < WAVE_LEN; i++) {
    wave[i] = i;
  }

  // BIG loop marker
  for (int i = 0; i < 50; i++) {
    wave[i] = 0;
  }
  wave[50] = 255;
}

void loop() {
  for (int i = 0; i < WAVE_LEN; i++) {
    analogWrite(OUTPUT_PIN, wave[i]);
    delayMicroseconds(200);
  }
}
