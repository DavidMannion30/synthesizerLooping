#include <Arduino.h>

#define OUTPUT_PIN 3
#define WAVE_LEN 256

uint8_t wave[WAVE_LEN];

void setup() {
  pinMode(OUTPUT_PIN, OUTPUT);

  // Mostly silence
  for (int i = 0; i < WAVE_LEN; i++) {
    wave[i] = 128;   // mid level
  }

  // A short burst at the start of each loop
  for (int i = 0; i < 12; i++) {
    wave[i] = 255;
  }
  for (int i = 12; i < 24; i++) {
    wave[i] = 0;
  }
}

void loop() {
  for (int i = 0; i < WAVE_LEN; i++) {
    analogWrite(OUTPUT_PIN, wave[i]);
    delayMicroseconds(400);
  }

  // obvious gap between repeats
  analogWrite(OUTPUT_PIN, 128);
  delay(300);
}
